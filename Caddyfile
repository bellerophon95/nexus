{
    email {$CADDY_EMAIL}
}

{$DOMAIN_NAME} {
    # Backend (FastAPI) API routes
    handle /api/* {
        reverse_proxy backend:8000 {
            flush_interval -1
            header_up Connection "keep-alive"
            header_up X-Accel-Buffering "no"
            lb_try_duration 120s
            lb_try_interval 5s
        }
    }

    # Frontend (Next.js) - everything else
    handle {
        reverse_proxy frontend:3000
    }

    # Logging
    log {
        output file /var/log/caddy/access.log
    }
}
